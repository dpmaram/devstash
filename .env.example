# Runtime connection for Prisma Client.
# Use the pooled Neon connection string for serverless runtimes.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Direct Neon connection for Prisma CLI and migrations.
# Do not use the pooler host for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Optional dedicated shadow database for Prisma Migrate.
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/SHADOW_DB?sslmode=require"

# Auth.js runtime secret. Generate with: npx auth secret
AUTH_SECRET="replace-with-random-secret"

# GitHub OAuth app credentials.
AUTH_GITHUB_ID="replace-with-github-client-id"
AUTH_GITHUB_SECRET="replace-with-github-client-secret"
