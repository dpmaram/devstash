# Runtime connection for Prisma Client.
# Use the pooled Neon connection string for serverless runtimes.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"

# Direct Neon connection for Prisma CLI and migrations.
# Do not use the pooler host for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"

# Optional dedicated shadow database for Prisma Migrate.
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/SHADOW_DB?sslmode=require"

# Auth.js runtime secret. Generate with: npx auth secret
AUTH_SECRET="replace-with-random-secret"

# GitHub OAuth app credentials.
AUTH_GITHUB_ID="replace-with-github-client-id"
AUTH_GITHUB_SECRET="replace-with-github-client-secret"

# Public application URL used for email verification links.
APP_URL="http://localhost:3000"

# Set to "false" to skip Resend email verification in local development.
EMAIL_VERIFICATION_ENABLED="true"

# Resend transactional email settings.
RESEND_API_KEY="replace-with-resend-api-key"
RESEND_FROM_EMAIL="DevStash <onboarding@example.com>"

# Upstash Redis REST credentials for auth rate limiting.
UPSTASH_REDIS_REST_URL="replace-with-upstash-redis-rest-url"
UPSTASH_REDIS_REST_TOKEN="replace-with-upstash-redis-rest-token"

# AWS S3 upload storage.
# S3_BUCKET_NAME and S3_UPLOAD_PREFIX default to these values in code.
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="replace-with-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="replace-with-aws-secret-access-key"
S3_BUCKET_NAME="eapi-chc-dev-ets-attachments"
S3_UPLOAD_PREFIX="devstash/api/uploads/dm"
